rules_version = '2';
// Each signed-in user can read and write only their own document tree.
// Nobody can read or write anyone else's data, and unauthenticated
// (guest, never-signed-in) clients cannot touch the cloud at all.
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /cigarettes/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
